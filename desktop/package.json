{
  "name": "baustift-desktop",
  "version": "1.0.0",
  "description": "Desktop-Wrapper für die Baustift-App (Bautagesberichte)",
  "author": "Elias Kümmel <eliaskummel@gmail.com>",
  "main": "main.js",
  "private": true,
  "license": "SEE LICENSE IN ../LICENSE",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^37.7.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.eliaskummel.baustift",
    "productName": "Baustift",
    "copyright": "Copyright © 2026 Elias Kümmel. Alle Rechte vorbehalten.",
    "files": ["main.js", "error.html", "node_modules/**/*"],
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kr511",
        "repo": "tagesberichte"
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "Baustift-Setup.exe",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "Baustift-Portable.exe"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": ["AppImage"],
      "category": "Office",
      "artifactName": "Baustift.AppImage"
    }
  }
}
